# OpenAI-compatible chat endpoint used by MAS agents and ConMem updates.
LLM_API_KEY=EMPTY
LLM_BASE_URL=http://127.0.0.1:8100/v1
LLM_MODEL=Qwen/Qwen3-4B-Instruct-2507

# Embedding endpoint used by ConMem retrieval.
CONMEM_EMBED_API_KEY=EMPTY
CONMEM_EMBED_BASE_URL=http://127.0.0.1:8002/v1
CONMEM_EMBED_MODEL=Qwen/Qwen3-Embedding-0.6B
CONMEM_EMBED_DEVICE=cpu

# Optional retrieval service for factual QA environments.
SEARCH_URL=http://127.0.0.1:8000/retrieve

# Optional ReMe HTTP service wrapper.
REME_ROOT=/path/to/reme
REME_HOST=127.0.0.1
REME_PORT=8003
REME_LLM_MODEL=Qwen/Qwen3-4B-Instruct-2507
REME_EMBED_MODEL=Qwen/Qwen3-Embedding-0.6B

# Common ConMem controls.
TOPK=5
CONMEM_TOKEN_BUDGET=1536
CONMEM_ENABLE_GRAPH_EXPANSION=1
CONMEM_ENABLE_COORDINATION=1
CONMEM_ENABLE_FAILURE_REFLECTION=1
CONMEM_ENABLE_FAILURE_ADMISSION=1
